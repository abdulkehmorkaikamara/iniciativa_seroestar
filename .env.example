# Root environment variables for local development

# Backend database connection
ENVIRONMENT=development
DATABASE_URL=postgresql://postgres:replace-me@localhost:5432/ser_ostar_db
JWT_SECRET=generate-a-long-random-value
ADMIN_EMAIL=admin@seroestar.com
ADMIN_PASSWORD=replace-with-a-strong-password
DAILY_API_KEY=
DAILY_DOMAIN=seroestar.daily.co
FRONTEND_ORIGINS=http://localhost:3000
COOKIE_SECURE=false
BLOB_READ_WRITE_TOKEN=
RECORDING_WEBHOOK_SECRET=

# AI proxy (required for chatbot functionality)
OPENAI_API_KEY=

# Express server / frontend host configuration
APP_URL=http://localhost:3000

# SMTP / Gmail configuration for guided outbound email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=admin@seroestar.com
SMTP_PASS=replace-with-an-app-password
SMTP_FROM_NAME="Iniciativa Ser o Estar"
SMTP_FROM_EMAIL=admin@seroestar.com
