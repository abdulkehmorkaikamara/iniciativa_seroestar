# Backend environment variables for FastAPI / PostgreSQL
ENVIRONMENT=development
DATABASE_URL=postgresql://postgres:replace-me@localhost:5432/ser_ostar_db
JWT_SECRET=generate-a-long-random-value
ADMIN_EMAIL=admin@seroestar.com
ADMIN_PASSWORD=replace-with-a-strong-password
DAILY_API_KEY=
DAILY_DOMAIN=seroestar.daily.co
FRONTEND_ORIGINS=http://localhost:3000
COOKIE_SECURE=false
BLOB_READ_WRITE_TOKEN=
RECORDING_WEBHOOK_SECRET=

# Optional: set this if you want to run the backend from a different root path
# APP_URL=http://localhost:3000
